3rdp/build/
build_*/
3rdp/dist/

# macOS
.DS_Store

# Secrets / signing artifacts - never commit these
*.p12
*.env
apple-codesign*

# CI artifacts
artifacts/

# CLIO (managed automatically)
.clio/*
!.clio/instructions.md

# Reference materials (local only)
reference/
scratch/
ai-assisted/
